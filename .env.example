# Strata Environment Configuration
# Copy to .env and modify as needed
#
# All settings can also be configured in pyproject.toml under [tool.strata]

# =============================================================================
# Server Settings
# =============================================================================

# Host to bind the server (use 0.0.0.0 for Docker)
STRATA_HOST=127.0.0.1

# Port for the HTTP API
STRATA_PORT=8765

# =============================================================================
# Cache Settings
# =============================================================================

# Directory for the disk cache (Arrow IPC files + SQLite metadata)
STRATA_CACHE_DIR=~/.strata/cache

# Maximum cache size in bytes (default: 10GB)
STRATA_MAX_CACHE_SIZE_BYTES=10737418240

# =============================================================================
# Resource Limits (Backpressure)
# =============================================================================

# These can be set in pyproject.toml [tool.strata] section:
#
# max_concurrent_scans = 100      # Max scans executing at once
# max_tasks_per_scan = 1000       # Max row groups per scan
# scan_timeout_seconds = 300.0    # 5 minute timeout per scan
# max_response_bytes = 1073741824 # 1 GB max response size

# =============================================================================
# Observability
# =============================================================================

# Disable metrics logging (useful for benchmarks)
# STRATA_METRICS_ENABLED=false
